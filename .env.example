# backend 실행에 필요한 환경변수 목록.
# 로컬 개발: 이 파일을 .env로 복사하고 값을 채운 뒤 `set -a; source .env; set +a`로 로드하거나
# IDE 실행 구성의 환경변수로 등록한다. (.env는 gitignore 대상)

# --- Database (docker-compose 기본값과 동일, 로컬에선 생략 가능) ---
DB_URL=jdbc:postgresql://localhost:5432/kcalog
DB_USERNAME=kcalog
DB_PASSWORD=kcalog

# --- JWT (운영 필수, 로컬은 기본값 사용 가능. 32바이트 이상) ---
JWT_SECRET=

# --- 카카오 OAuth (developers.kakao.com 앱의 REST API 키 / Client Secret) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- 프론트엔드 주소 (OAuth 성공 후 리다이렉트 대상) ---
FRONTEND_BASE_URL=http://localhost:5173
